{
  "name": "maturador-ajcred",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "deps:ensure": "node scripts/ensure-deps.js",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:frontend:wait": "wait-on http-get://127.0.0.1:3001/health && npm run dev:frontend",
    "dev": "concurrently -n backend,frontend -c yellow,cyan \"npm run dev:backend\" \"npm run dev:frontend:wait\"",
    "build:frontend": "npm run build --prefix frontend",
    "predev": "npm run deps:ensure",
    "prelan": "npm run deps:ensure",
    "lan": "npm run build:frontend && cross-env SERVE_FRONTEND=true HOST=0.0.0.0 PORT=500 npm run start --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "wait-on": "^8.0.5"
  }
}
